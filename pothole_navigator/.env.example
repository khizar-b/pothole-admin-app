# Google Maps Platform API key.
# Enable these APIs on the key's Google Cloud project (billing must be on):
#   - Maps SDK for Android   (the map view)
#   - Routes API             (routes + alternatives)
#   - Places API (New)       (destination search)
GOOGLE_MAPS_API_KEY=YOUR_GOOGLE_MAPS_API_KEY_HERE

# Pothole admin backend.
# Android emulator -> host machine: http://10.0.2.2:5000
# Physical device on same WiFi:     http://<your-pc-lan-ip>:5000
API_BASE_URL=http://10.0.2.2:5000
